{
  "name": "securityshrimp-anti-phishing-extension",
  "version": "1.1.0",
  "description": "Augment the web with indicators that help detect phishing attempts",
  "private": true,
  "type": "module",
  "scripts": {
    "vendor": "node scripts/copy-libs.mjs",
    "build": "npm run vendor && node scripts/build.mjs",
    "lint": "eslint .",
    "lint:webext": "web-ext lint --source-dir=dist/firefox",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,mjs,json,html,css,md}\""
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "color-hash": "^1.0.3",
    "crc-32": "^1.2.2",
    "psl": "^1.9.0",
    "punycode": "^2.3.1",
    "tippy.js": "^6.3.7",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.0",
    "web-ext": "^10.3.0"
  },
  "engines": {
    "node": ">=20"
  }
}
